{
  "name": "dashboard-monorepo",
  "private": true,
  "workspaces": [
    "front-end",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n fe,api -c cyan,magenta \"npm run dev -w front-end\" \"npm run dev -w server\"",
    "dev:client": "npm run dev -w front-end",
    "dev:server": "npm run dev -w server",
    "build": "npm run build -w front-end",
    "build:server": "npm run build -w server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
